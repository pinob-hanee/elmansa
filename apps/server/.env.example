PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/elmansa_lms"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-64-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-change-in-production-min-64-chars"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/auth/google/callback"

# Frontend URL
CLIENT_URL="http://localhost:5173"

# AWS / Cloudflare R2
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="auto"
AWS_S3_BUCKET="elmansa-media"
AWS_ENDPOINT_URL="https://your-r2-endpoint.r2.cloudflarestorage.com"
CLOUDFRONT_DOMAIN="https://media.elmansa.com"
CLOUDFRONT_KEY_PAIR_ID="your-cf-key-pair-id"
CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Email (Nodemailer / SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
SMTP_FROM="noreply@elmansa.com"
SMTP_FROM_NAME="Elmansa LMS"

# App
APP_NAME="Elmansa"
APP_URL="http://localhost:5000"
